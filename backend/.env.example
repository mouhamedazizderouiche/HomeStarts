PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/homestars

# Transfermarkt source (published CSV)
TRANSFERMARKT_PLAYERS_CSV_URL=https://pub-e682421888d945d684bcae8890b0ec20.r2.dev/data/players.csv.gz
# Optional local override:
# TRANSFERMARKT_PLAYERS_CSV_PATH=C:/path/to/players.csv
# PLAYERS_CSV_PATH=C:/work/HomeStars/data/players.csv

# ETL controls
ETL_BATCH_SIZE=500
ETL_MAX_ROWS=0
ETL_MAX_SPORTSDB_ENRICH=500
ETL_SPORTSDB_DELAY_MS=300
ETL_HTTP_TIMEOUT_MS=18000
IMPORT_WRITE_BATCH_SIZE=400
IMPORT_MAX_SPORTSDB_ENRICH=1200
IMPORT_SPORTSDB_DELAY_MS=350
ACTIVE_MIN_SEASON=2024
WIKIPEDIA_MAX_COUNTRIES=80
WIKIPEDIA_MIN_COUNTRY_TARGET=60
WIKIPEDIA_DELAY_MS=400
WIKIPEDIA_PRIORITY_COUNTRIES=Tunisia,Morocco,Algeria,Egypt,Senegal,Nigeria,Ghana,Cameroon,Mali,South Africa,Ivory Coast,Saudi Arabia,Qatar,UAE,Japan,South Korea,Australia,United States,Mexico

# Optional FBref source (CSV)
# FBREF_PLAYERS_CSV_PATH=C:/work/HomeStars/data/fbref/players.csv
# FBREF_PLAYERS_CSV_URL=https://example.com/fbref_players.csv

# Optional Confederation source (local only)
# CONFED_PLAYERS_JSON_PATH=C:/work/HomeStars/data/confederation/players.json
# CONFED_PLAYERS_CSV_PATH=C:/work/HomeStars/data/confederation/players.csv

# TheSportsDB enrichment
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json/123/
SPORTSDB_TIMEOUT_MS=12000
PLAYER_PLACEHOLDER_IMAGE=https://www.thesportsdb.com/images/media/player/cutout/default.png
PLAYERS_PER_COUNTRY_LIMIT=60
TOP_PLAYERS_LIMIT=10
MATCH_CACHE_TTL_SECONDS=600
CALENDAR_WINDOW_DAYS=7
NEXT_MATCH_WINDOW_DAYS=14
MATCHES_LOOKAHEAD_DAYS=14
MATCHES_MIN_LOOKAHEAD_DAYS=7
MATCHES_RATE_DELAY_MS=6000
FOOTBALL_DATA_API_KEY=your_key_here
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITIONS=PL,PD,SA,BL1,FL1,DED,PPL,ELC,CLI
# SUPABASE_MATCHES_TABLE=matches

# Wikipedia national team enrichment
WIKIPEDIA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# WIKI_OUTPUT_JSON=C:/work/HomeStars/data/wikipedia/national-team-players-2026-04-18.json
# WIKI_INPUT_JSON=C:/work/HomeStars/data/wikipedia/national-team-players-2026-04-18.json
# WIKI_COUNTRY_LIMIT=3
# WIKI_COUNTRIES=tn,ma,dz

# Supabase (for wikipedia -> players enrichment)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY
# SUPABASE_PLAYERS_TABLE=players

# Transfermarkt diaspora scraper
TRANSFERMARKT_PROFILE_DELAY_MS=3000
TRANSFERMARKT_PROFILE_CONCURRENCY=2
TRANSFERMARKT_MAX_RETRIES=3
TRANSFERMARKT_TIMEOUT_MS=30000
TRANSFERMARKT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
