{
  "name": "homestars-backend",
  "version": "1.0.0",
  "description": "Mock API for HomeStars MVP",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build-dataset": "node ../scripts/etl/importPlayers.js",
    "supabase:import-csv": "node ../scripts/etl/importPlayersFromCSV.js",
    "etl:images": "node ../scripts/etl/enrichPlayerImages.js",
    "etl:enrich-full": "node ../scripts/etl/enrichPlayersFull.js",
    "etl:enrich-full-data": "node ../scripts/etl/enrichFullData.js",
    "scrape:transfermarkt": "node ../scripts/scraper/transfermarktScraper.js",
    "scrape:soccerway": "node ../scripts/scraper/soccerwayScraper.js",
    "update-players": "node ../scripts/etl/updateWeekly.js",
    "sync-matches": "node ../scripts/etl/syncMatches.js",
    "wiki:scrape-national-teams": "node ../scripts/wikipedia/scrapeNationalTeams.js",
    "wiki:scrape-bible": "node ../scripts/wikipedia/scrapeUrlBible.js",
    "wiki:enrich-supabase": "node ../scripts/wikipedia/enrichSupabasePlayers.js",
    "supabase:clean-players": "node ../scripts/supabase/cleanPlayersData.js",
    "supabase:normalize-countries": "node ../scripts/supabase/normalizeCountryData.js",
    "supabase:rebuild-countries": "node ../scripts/supabase/rebuildCountriesTable.js",
    "supabase:backfill-assets": "node ../scripts/supabase/backfillTransfermarktAssets.js",
    "supabase:update-scores": "node ../scripts/supabase/updatePlayerScores.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.7.7",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.6.1",
    "node-cache": "^5.1.2",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
